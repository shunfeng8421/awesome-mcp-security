{
  "nodes": {
    "CWE-22": {
      "type": "weakness",
      "name": "Path Traversal",
      "severity": "HIGH",
      "connects_to": ["pattern-15", "pattern-1", "cherrystudio-cve-1"],
      "fix": "validate_safe_path() + os.path.realpath()"
    },
    "CWE-306": {
      "type": "weakness", 
      "name": "Missing Authentication",
      "severity": "HIGH",
      "connects_to": ["memoryos-cve", "pattern-auth-1"],
      "fix": "Add FastAPI Depends(auth) middleware"
    },
    "CWE-918": {
      "type": "weakness",
      "name": "SSRF",
      "severity": "HIGH",
      "connects_to": ["cherrystudio-cve-2", "pattern-ssrf"],
      "fix": "URL allowlist + dns rebinding protection"
    },
    "CWE-798": {
      "type": "weakness",
      "name": "Hardcoded Credentials",
      "severity": "HIGH",
      "connects_to": ["kimai-cve", "semgrep-rule-P5"],
      "fix": "os.environ.get() + secret manager"
    },

    "pattern-15": {
      "type": "pattern",
