      "fix": "Add API key middleware to FastAPI router"
    },

    "mcp-scan-AS1": {
      "type": "tool",
      "tool": "mcp-scan",
      "connects_to": ["pattern-15", "CWE-22", "cherrystudio-cve-1"],
