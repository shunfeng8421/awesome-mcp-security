      "connects_to": ["CWE-22", "cherrystudio-cve-1", "mcp-scan-AS1"],
      "search": "file_path parameter + open() without validate_safe_path()",
      "category": "MCP"
    },
    "pattern-16": {
      "type": "pattern",
