      "search": "auth middleware + URL segment parsing mismatch",
      "category": "Web"
    },
    "pattern-1": {
      "type": "pattern",
      "name": "通用路径遍历",
      "connects_to": ["CWE-22"],
      "search": "open(file_path) from request without validation",
      "category": "Web"
    },

    "cherrystudio-cve-1": {
      "type": "cve",
      "id": "cherrystudio-qq-mcp #1",
      "connects_to": ["CWE-22", "pattern-15", "mcp-scan-AS1"],
      "impact": "Unauthenticated arbitrary file read on MCP server",
      "fix": "Add validate_safe_path(file_path) before open()"
    },
    "cherrystudio-cve-2": {
      "type": "cve",
      "id": "cherrystudio-qq-mcp #2", 
